<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StarterApp.Views.RentalsPage"
             Title="Rentals">
    <VerticalStackLayout Padding="20" Spacing="10">

        <!-- Tab buttons -->
        <Grid ColumnDefinitions="*,*">
            <Button Grid.Column="0" Text="Incoming"
                    Command="{Binding ShowIncomingCommand}"
                    BackgroundColor="{Binding IncomingButtonColor}" />
            <Button Grid.Column="1" Text="Outgoing"
                    Command="{Binding ShowOutgoingCommand}"
                    BackgroundColor="{Binding OutgoingButtonColor}" />
        </Grid>

        <Label Text="{Binding StatusMessage}" TextColor="Red" />

        <!-- Incoming Rentals -->
        <CollectionView ItemsSource="{Binding IncomingRentals}"
                        IsVisible="{Binding IsIncomingSelected}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Padding="10" Spacing="5">
                        <Label Text="{Binding ItemTitle}" FontAttributes="Bold" />
                        <Label Text="{Binding BorrowerName, StringFormat='From: {0}'}" />
                        <Label Text="{Binding Status}" />
                        <Label Text="{Binding StartDate, StringFormat='Start: {0:dd/MM/yyyy}'}" />
                        <Label Text="{Binding EndDate, StringFormat='End: {0:dd/MM/yyyy}'}" />
                        <Label Text="{Binding TotalPrice, StringFormat='Total: £{0:F2}'}" />

                        <Grid ColumnDefinitions="*,*" IsVisible="{Binding IsRequested}">
                            <Button Grid.Column="0" Text="Approve"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ApproveRentalCommand}"
                                    CommandParameter="{Binding}" />
                            <Button Grid.Column="1" Text="Reject"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RejectRentalCommand}"
                                    CommandParameter="{Binding}" />
                        </Grid>

                        <!-- Mark as Out for Rent for Approved -->
<Button Text="Mark as Out for Rent"
        IsVisible="{Binding IsApproved}"
        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MarkOutForRentCommand}"
        CommandParameter="{Binding}" />

                                                <Button Text="Mark as Completed"
                                                    IsVisible="{Binding IsReturned}"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MarkCompletedCommand}"
                                                    CommandParameter="{Binding}" />

                        <BoxView HeightRequest="1" Color="LightGray" />
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Outgoing Rentals -->
        <CollectionView ItemsSource="{Binding OutgoingRentals}"
                        IsVisible="{Binding IsIncomingSelected, Converter={StaticResource InvertedBoolConverter}}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Padding="10" Spacing="5">
                        <Label Text="{Binding ItemTitle}" FontAttributes="Bold" />
                        <Label Text="{Binding OwnerName, StringFormat='Owner: {0}'}" />
                        <Label Text="{Binding Status}" />
                        <Label Text="{Binding StartDate, StringFormat='Start: {0:dd/MM/yyyy}'}" />
                        <Label Text="{Binding EndDate, StringFormat='End: {0:dd/MM/yyyy}'}" />
                        <Label Text="{Binding TotalPrice, StringFormat='Total: £{0:F2}'}" />
                        <Button Text="Mark as Returned"
                                IsVisible="{Binding IsOutForRent}"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MarkReturnedCommand}"
                                CommandParameter="{Binding}" />
                        <Button Text="Mark as Returned (Overdue)"
                                IsVisible="{Binding IsOverdue}"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MarkReturnedCommand}"
                                CommandParameter="{Binding}" />
                        <Button Text="Leave a Review"
                                IsVisible="{Binding Status, Converter={StaticResource StringEqualsConverter}, ConverterParameter='Completed'}"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.LeaveReviewCommand}"
                                CommandParameter="{Binding}" />
                        <BoxView HeightRequest="1" Color="LightGray" />
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>