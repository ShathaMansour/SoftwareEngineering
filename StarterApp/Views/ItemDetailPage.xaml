<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             x:Class="StarterApp.Views.ItemDetailPage"
             Title="Item Details">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- View mode -->
            <VerticalStackLayout IsVisible="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}">
                <Label Text="Title" FontAttributes="Bold" />
                <Label Text="{Binding Title}" FontSize="20" />

                <Label Text="Description" FontAttributes="Bold" />
                <Label Text="{Binding Description}" />

                <Label Text="Category" FontAttributes="Bold" />
                <Label Text="{Binding Category}" />

                <Label Text="Daily Rate" FontAttributes="Bold" />
                <Label Text="{Binding DailyRate, StringFormat='£{0:F2}'}" />
            </VerticalStackLayout>

            <!-- Edit mode -->
            <VerticalStackLayout IsVisible="{Binding IsEditing}" Spacing="10">
                <Label Text="Title" FontAttributes="Bold" />
                <Entry Text="{Binding Title}" />

                <Label Text="Description" FontAttributes="Bold" />
                <Editor Text="{Binding Description}" HeightRequest="100" />

                <Label Text="Category" FontAttributes="Bold" />
                <Picker Title="Select Category"
                        ItemsSource="{Binding Categories}"
                        ItemDisplayBinding="{Binding Name}"
                        SelectedItem="{Binding SelectedCategory}" />

                <Label Text="Daily Rate" FontAttributes="Bold" />
                <Entry Text="{Binding DailyRate, StringFormat='{0:F2}'}" Keyboard="Numeric" />
            </VerticalStackLayout>

            <!-- Owner actions -->
            <VerticalStackLayout IsVisible="{Binding IsOwner}" Spacing="10">
                <Button Text="Edit Item"
                        Command="{Binding ToggleEditCommand}"
                        IsVisible="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}" />
                <Button Text="Save Changes"
                        Command="{Binding SaveChangesCommand}"
                        IsVisible="{Binding IsEditing}" />
                <Button Text="Cancel"
                        Command="{Binding ToggleEditCommand}"
                        IsVisible="{Binding IsEditing}" />
            </VerticalStackLayout>

            <!-- Rent section (non-owners only) -->
            <VerticalStackLayout IsVisible="{Binding IsOwner, Converter={StaticResource InvertedBoolConverter}}"
                                 Spacing="8">
                <Label Text="Request a Rental" FontAttributes="Bold" FontSize="16" />
                <Label Text="Start Date" />
                <DatePicker Date="{Binding StartDate}" MinimumDate="{x:Static sys:DateTime.Today}" />
                <Label Text="End Date" />
                <DatePicker Date="{Binding EndDate}" MinimumDate="{x:Static sys:DateTime.Today}" />
                <Button Text="Request Rental" Command="{Binding RentItemCommand}" />
                <Label Text="{Binding StatusMessage}" TextColor="Red" />
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray" />

            <!-- Reviews button -->
            <Button Text="View Reviews" Command="{Binding ViewReviewsCommand}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>