<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StarterApp.Views.ItemsListPage"
             Title="Items">

    <Grid RowDefinitions="Auto,*">

    <Grid Grid.Row="0" ColumnDefinitions="*,*,*,*" Margin="20,10">
        <Button Grid.Column="0" Text="Create Item" Command="{Binding GoToCreateItemCommand}" />
        <Button Grid.Column="1" Text="MyRentals" Command="{Binding GoToRentalsCommand}" />
        <Button Grid.Column="2" Text="Near Me" Command="{Binding GoToNearbyCommand}" />
        <Button Grid.Column="3" Text="Profile" Command="{Binding GoToProfileCommand}" />
    </Grid>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Items}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Padding="10">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.ViewItemCommand}"
                                CommandParameter="{Binding .}" />
                        </VerticalStackLayout.GestureRecognizers>
                        <Label Text="{Binding Title}" FontSize="20"/>
                        <Label Text="{Binding Description}" />
                        <Label Text="{Binding DailyRate}" />
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>