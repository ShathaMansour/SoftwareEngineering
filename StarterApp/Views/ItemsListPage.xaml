<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StarterApp.Views.ItemsListPage"
             Title="Items">

    <Grid RowDefinitions="Auto,*">

        <Button Grid.Row="0"
                Text="Create Item"
                Margin="20,10"
                Command="{Binding GoToCreateItemCommand}" />

<CollectionView Grid.Row="1" ItemsSource="{Binding Items}">
    <CollectionView.ItemTemplate>
        <DataTemplate>
            <VerticalStackLayout Padding="10">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer 
                        Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.ViewItemCommand}"
                        CommandParameter="{Binding .}" />
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="{Binding Title}" FontSize="20"/>
                <Label Text="{Binding Description}" />
                <Label Text="{Binding DailyRate}" />
            </VerticalStackLayout>
        </DataTemplate>
    </CollectionView.ItemTemplate>
</CollectionView>

    </Grid>

</ContentPage>